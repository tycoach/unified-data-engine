{
    "title": "UDE — Engine Overview",
    "uid": "ude-engine-overview",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Batch Throughput (records/batch)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(ude_batch_records_total[5m])",
            "legendFormat": "{{ pipeline_id }}"
          }
        ]
      },
      {
        "id": 2,
        "title": "End-to-End Batch Duration (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ude_batch_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 {{ pipeline_id }}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Quarantine Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "ude_quarantine_rate",
            "legendFormat": "{{ pipeline_id }}"
          }
        ],
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.10}
            ]
          }
        }
      },
      {
        "id": 4,
        "title": "Active Pipelines",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
        "targets": [
          {"expr": "ude_active_pipelines", "legendFormat": "pipelines"}
        ]
      },
      {
        "id": 5,
        "title": "Schema Version per Pipeline",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "ude_schema_version",
            "legendFormat": "{{ pipeline_id }}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Staging Rows Written",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
        "targets": [
          {
            "expr": "rate(ude_staging_rows_written_total[5m])",
            "legendFormat": "{{ pipeline_id }}"
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "pipeline",
          "type": "query",
          "query": "label_values(ude_batch_records_total, pipeline_id)",
          "current": {"value": "customers"}
        }
      ]
    }
  }