{# cli/scaffold/templates/engine.yml.j2 #}
{# config/engine.yml #}
{# Generated by: ude init #}
{# Global engine configuration — applies to all pipelines. #}
{# Per-pipeline overrides go in config/pipelines/{id}.yml #}

# config/engine.yml

project: {{ project_name }}
environment: {{ env }}           # local | staging | production

gcp:
  project_id: {{ gcp_project }}
{% if is_local %}
  emulator_host: localhost:9099  # MiniSky local GCP emulator
{% endif %}

pubsub:
  batch_window_seconds: 30       # micro-batch collection window
  max_messages_per_pull: 1000

bigquery:
  staging_dataset: raw_staging
  quarantine_dataset: quarantine

dbt:
  project_dir: dbt/
  profiles_dir: dbt/
  target: "{% if is_local %}dev{% else %}prod{% endif %}"

engine:
  batch_window_seconds: 30
  null_threshold: 0.05           # default — overridable per pipeline
  late_arrival_window: 24h
  duplicate_window: 30m
  edge_case_mode: quarantine     # quarantine | skip | fail

api:
  host: 0.0.0.0
  port: 8000

metrics:
  pushgateway_url: http://localhost:9091
  scrape_interval_seconds: 15

logging:
  level: INFO                    # DEBUG | INFO | WARNING | ERROR
  format: json                   # json | text
