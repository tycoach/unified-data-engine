# cli/scaffold/templates/pipeline.yml.j2
# config/pipelines/{{ pipeline_id }}.yml
# Generated by: ude pipeline new
# Edit freely — the engine hot-reloads this file on every batch cycle.

pipeline_id: {{ pipeline_id }}
subscription_id: {{ subscription_id }}
natural_key: {{ natural_key }}
scd_type: {{ scd_type }}              # 1 = overwrite (incremental), 2 = full history (snapshot)

edge_case_mode: quarantine            # quarantine | skip | fail
null_threshold: {{ null_threshold }}  # fraction of records allowed to have nulls (0.0–1.0)
late_arrival_window: {{ late_arrival_window }}
duplicate_window: {{ duplicate_window }}

dbt:
  staging_model: {{ staging_model }}
  mart_model: {{ mart_model }}
{% if has_snapshot %}
  snapshot: {{ snapshot_name }}
  snapshot_strategy: timestamp        # timestamp | check
  check_cols: []                      # used only if strategy=check
  invalidate_hard_deletes: true       # close SCD Type 2 record when source row disappears
{% else %}
  snapshot: null                      # no snapshot for SCD Type 1
{% endif %}
  tests:
    - not_null: [{{ natural_key }}, updated_at]
    - unique: [{{ natural_key }}]

schema:
  # Populated automatically by the engine on first load — do not edit manually.
  locked_version: null
  locked_at: null

fields:
{% for field_name, meta in fields.items() %}
  {{ field_name }}: { type: {{ meta.type }}, nullable: {{ meta.nullable | lower }} }
{% endfor %}
