# .env.example
# Unified Data Engine v2 — environment variables
# Copy to .env and fill in values
# cp .env.example .env

# ── MiniSky / GCP ────────────────────────────────────────────────────────────
GCP_PROJECT_ID=local-dev-project
MINISKY_HOST=http://localhost:8080
MINISKY_API_PORT=8080
MINISKY_UI_PORT=8081

# ── Engine ────────────────────────────────────────────────────────────────────
BATCH_WINDOW_SECONDS=30
LOG_LEVEL=INFO

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_TARGET=dev
DBT_PROJECT_DIR=./dbt
DBT_PROFILES_DIR=./dbt

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Pub/Sub topics ────────────────────────────────────────────────────────────
PUBSUB_CUSTOMERS_TOPIC=raw.customers
PUBSUB_ORDERS_TOPIC=raw.orders
PUBSUB_CUSTOMERS_SUB=raw.customers-sub
PUBSUB_ORDERS_SUB=raw.orders-sub

# ── State paths (local dev) ───────────────────────────────────────────────────
SCHEMA_REGISTRY_DIR=.schema_registry
STATE_DIR=.state

# ── Production overrides (leave blank for local dev) ─────────────────────────
# GCP_SERVICE_ACCOUNT_KEY=/path/to/key.json
# BIGQUERY_DATASET=marts
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
